{
  "openapi": "3.0.3",
  "info": {
    "title": "GREEN ARGRIC API",
    "version": "1.0.0",
    "description": "API giám sát vườn thủy canh, thiết bị, cảnh báo và lịch công việc."
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Đăng nhập",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Thành công"
          }
        }
      }
    },
    "/dashboard": {
      "get": {
        "summary": "Dashboard tổng quan",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Thành công"
          }
        }
      }
    },
    "/area": {
      "get": {
        "summary": "Danh sách khu vực",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Thành công"
          }
        }
      }
    },
    "/sensor/area/{areaId}/latest": {
      "get": {
        "summary": "Dữ liệu cảm biến mới nhất",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "areaId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Thành công"
          }
        }
      }
    },
    "/device/override": {
      "post": {
        "summary": "Điều khiển thiết bị thủ công",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Thành công"
          }
        }
      }
    },
    "/alert": {
      "get": {
        "summary": "Danh sách cảnh báo",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Thành công"
          }
        }
      }
    },
    "/task": {
      "get": {
        "summary": "Danh sách công việc",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Thành công"
          }
        }
      }
    }
  }
}